# ─────────────────────────────────────────────
# LESFeedback — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Database (all apps) ──────────────────────
# Neon PostgreSQL connection string
# https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Landing (apps/landing) ───────────────────
# Secret for the manual migration endpoint (POST /api/waitlist/migrate)
# Any random string — generate with: openssl rand -base64 32
MIGRATION_SECRET=

# Public URL of the dashboard app — used in CTA buttons (LES-15)
# Dev: http://localhost:3001 | Prod: https://app.lesfeedback.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Dashboard (apps/web) ─────────────────────
# Better Auth secret — generate with: openssl rand -base64 32 (LES-7)
BETTER_AUTH_SECRET=

# Better Auth URL — base URL of the dashboard app
# Dev: http://localhost:3001 | Prod: https://app.lesfeedback.com
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth credentials (LES-7)
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public URL of the widget.js file — shown in embed snippet UI (LES-11)
# Dev: http://localhost:5173/widget.iife.js | Prod: https://widget.lesfeedback.com/widget.js
NEXT_PUBLIC_WIDGET_URL=http://localhost:5173/widget.iife.js

# Sentry DSN for error monitoring (LES-17)
# https://sentry.io → your project → Settings → Client Keys
SENTRY_DSN=

# ── Widget (apps/widget) ─────────────────────
# URL of the dashboard API — widget uses this to POST feedback
# Dev: http://localhost:3001 | Prod: https://app.lesfeedback.com
VITE_API_URL=http://localhost:3001
